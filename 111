import os
import json
class Book():
    """图书类"""
    def __init__(self,id,title,author,price,isbn,status):
        self.id=id
        self.title = title
        self.author = author
        self.price = price
        self.isbn = isbn
        self.status=status
    def to_dict(self):
        return {
            'id':self.id,
            'title':self.title,
            'author':self.author,
            'price':self.price,
            'isbn':self.isbn,
            'status':self.status
        }
    @staticmethod
    def from_dict(data):
        return Book(
            data['id'],
            data['title'],
            data['author'],
            data['price'],
            data['isbn'],
            data['status']
        )
class User():
    """用户类"""
    def __init__(self,user_id,username,password,user_type):
        self.user_id=user_id
        self.username=username
        self.password=password
        self.user_type=user_type
    def to_dict(self):
        return {
            'user_id':self.user_id,
            'username':self.username,
            'password':self.password,
            'user_type':self.user_type,
        }
    @staticmethod
    def from_dict(data):
        return User(
            data['user_id'],
            data['username'],
            data['password'],
            data['user_type'],
        )
class Library():
    def __init__(self,books_file='books.json',users_file='users.json'):
        self.books_file=books_file
        self.users_file=users_file
        self.books={} #{book.id:Book}
        self.users={} #{user.id:User}
        self.current_user = None
        self.load_data()
    def load_data(self):
        if os.path.exists(self.books_file):
            try:
                with open(self.books_file,'r',encoding='utf-8')as f:
                    books_data=json.load(f)
                    for book_data in books_data.values():
                        book=Book.from_dict(book_data)
                        self.books[book.id]=book
            except:
                self.books={}
        if os.path.exists(self.users_file):
            try:
                with open(self.users_file,'r',encoding='utf-8')as f:
                    users_data=json.load(f)
                    for user_data in users_data.values():
                        user=User.from_dict(user_data)
                        self.users[user.user_id]=user
            except:
                self.users={}

    def save_data(self):
        books_dict={}
        for book_id,book in self.books.items():
            book_dict=book.to_dict()
            books_dict[book_id]=book_dict
        with open(self.books_file, 'w', encoding='utf-8') as f:
            json.dump(books_dict, f, ensure_ascii=False, indent=4)
        users_dict={}
        for user_id,user in self.users.items():
            user_dict=user.to_dict()
            users_dict[user_id]=user_dict
        with open(self.users_file,'w',encoding='utf-8')as f:
            json.dump(users_dict,f,ensure_ascii=False,indent=4)
    def register(self,user_id,username,password,user_type='普通用户'):
        if user_id in self.users:
            print(f'该用户已存在')
            return False
        else:
            self.users[user_id]=User(user_id,username,password,user_type)
            self.save_data()
            return True
    def login(self,password,user_id):
        if user_id in self.users:
            self.current_user = self.users[user_id]
            if self.users[user_id].password==password:
                print("欢迎回来")
                return True
            else:
                print("密码错误")
                return False
        else:
            print("该用户不存在")
            return False
    def logout(self):
        self.current_user =None
        print("再见")
        return True
    def add_book(self,title,author,price,isbn,status='在馆'):
        if not self.current_user or self.current_user.user_type!='管理员':
            print("需要管理员权限！")
            return False
        id=len(self.books)+1
        self.books[id]=Book(id,title,author,price,isbn,status)
        self.save_data()
        print("添加图书成功!")
        return True
    def display_books(self):
        if not self.books:
            print("暂无图书信息")
            return False
        else:
            print(f"{'图书id':<10}{'书名':<10}{'作者':<10}{'价格':<5}{'isbn':<5}{'状态':<5}")
            for book in self.books.values():
                print(f"{book.id:<10}{book.title:<10}{book.author:<10}{book.price:<5}{book.isbn:<5}{book.status:<5}")
            return True
    def search_book(self,keyword,search_by="title"):
        result=[]
        keyword=keyword.lower()
        for book in self.books.values():
            if search_by=="title" and keyword in book.title.lower():
                result.append(book)
            elif search_by=="author" and keyword in book.author.lower():
                result.append(book)
            elif search_by=="isbn" and keyword in book.isbn.lower():
                result.append(book)
            elif search_by=="id" and keyword in book.id.lower():
                result.append(book)
        return result
    def delete_book(self,id):
        """删除图书"""
        if not self.current_user or self.current_user.user_type!='管理员':
            print("需要管理员权限！")
            return False
        if id in self.books:
            del self.books[id]
            self.save_data()
            print("删除图书成功！")
            return True
        else:
            print("该图书不存在")
            return False
    def borrow_book(self,id):
        if id in self.books.keys():
            if self.books[id].status=='在馆':
                book=self.books[id]
                book.status='已借出'
                print(f"图书《{book.title}》借阅成功，请及时归还")
                return True
            else:
                print("图书已被借阅")
                return False
        else:
            print("未找到该图书")
            return False
    def return_book(self,id):
        if id in self.books.keys():
            book=self.books[id]
            if book.status=='已借出':
                print("还书成功")
                book.status='在馆'
                return True
            else:
                print("图书在馆")
                return False
        else:
            print("未找到该图书")
            return False



