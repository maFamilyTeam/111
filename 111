import os
import json
class Book():
    def __init__(self,book_id,title,price,author,isbn,status='在馆'):
        self.book_id = book_id
        self.title = title
        self.price = price
        self.author = author
        self.isbn = isbn
        self.status = status
    def to_dict(self):
        return {
            'book_id':self.book_id,
            'title':self.title,
            'price':self.price,
            'author':self.author,
            'isbn':self.isbn,
            'status':self.status
        }
    @staticmethod
    def to_json(data):
        return Book(
            data['book_id'],
            data['title'],
            data['price'],
            data['author'],
            data['isbn'],
            data['status']
        )
class User():
    def __init__(self,user_id,name,password,question,answer,user_type='普通用户'):
        self.user_id = user_id
        self.name = name
        self.password = password
        self.question = question
        self.answer = answer
        self.user_type = user_type
    def to_dict(self):
        return {
            'user_id':self.user_id,
            'name':self.name,
            'password':self.password,
            'question':self.question,
            'answer':self.answer,
            'user_type':self.user_type,
        }
    @staticmethod
    def to_json(data):
        return User(
            data['user_id'],
            data['name'],
            data['password'],
            data['question'],
            data['answer'],
            data['user_type']
        )
class Library():
    def __init__(self,books_file='books.json',users_file='users.json'):
        self.books_file = books_file
        self.users_file = users_file
        self.books={} #{book_id:Book}
        self.users={} #{user_id:User}
        self.current_user=None
        self.load_data()
    def load_data(self):
        if os.path.exists(self.books_file):
            try:
                with open(self.books_file,'r',encoding='utf-8')as f:
                    books_data=json.load(f)
                    for book_data in books_data.values():
                        book=Book.to_json(book_data)
                        self.books[book.book_id]=book
            except:
                self.books={}
        if os.path.exists(self.users_file):
            try:
                with open(self.users_file,'r',encoding='utf-8')as f:
                    users_data=json.load(f)
                    for user_data in users_data.values():
                        user=User.to_json(user_data)
                        self.users[user.user_id]=user
            except:
                self.users={}
    def save_data(self):
        books_dict={}
        for book_id,book in self.books.items():
            book_dict=book.to_dict()
            books_dict[book_id]=book_dict
        with open(self.books_file,'w',encoding='utf-8')as f:
            json.dump(books_dict,f,ensure_ascii=False,indent=4)
        users_dict={}
        for user_id,user in self.users.items():
            user_dict=user.to_dict()
            users_dict[user_id]=user_dict
        with open(self.users_file,'w',encoding='utf-8')as f:
            json.dump(users_dict,f,ensure_ascii=False,indent=4)
    def add_book(self):
        if not self.current_user or self.current_user.user_type!='管理员':
            print("需要管理员权限！")
            return False
        title=input("请输入图书名称：")
        price=input("图书价格：")
        author=input("图书作者：")
        isbn=input("图书ISBN：")
        for book in self.books.values():
            if book.isbn==isbn:
                print("ISBN已存在，添加失败！")
                return False
        if self.books:
            max_id=max(int(book_id) for book_id in self.books.keys())
            new_id=str(max_id+1)
        else:
            new_id="1"
        new_book=Book(new_id,title,price,author,isbn,status='在馆')
        self.books[new_id]=new_book
        self.save_data()
        print("添加图书成功！")
        return True
    def delete_book(self):
        if not self.current_user or self.current_user.user_type!='管理员':
            print("需要管理员权限！")
            return False
        id=input("请输入图书ID：")
        if not self.books:
            print("当前库中没有图书可删除！")
            return False
        if id not in self.books:
            print("图书不存在！")
            return False
        confirm=input(f"确定要删除ID为{id}的图书?(y/n):")
        if confirm.lower() == 'y':
            del self.books[id]
            self.save_data()
            print("删除成功")
            return True
    def edit_book(self):
        if not self.current_user or self.current_user.user_type != '管理员':
            print("需要管理员权限！")
            return False
        if not self.books:
            print("当前库没有图书可修改！")
            return False
        id=input("请输入要修改的图书ID：")
        if id not in self.books:
            print("未找到该图书！")
            return False
        book=self.books[id]
        new_title=input("请输入新书名：")
        new_price=input("新价格：")
        new_author=input("新作者：")
        new_isbn=input("新ISBN：")
        new_status=input("新状态：")
        if new_title:
            book.title=new_title
        if new_price:
            book.price=new_price
        if new_author:
            book.author=new_author
        if new_isbn:
            book.isbn=new_isbn
        if new_status:
            book.status=new_status
        self.save_data()
        print("图书修改成功！")
        return True
