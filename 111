                print("未找到该图书！")
        elif choice=='3':
            found = False
            author=input("请输入作者：")
            for book in self.books.values():
                if author in book.author:
                    print("找到图书")
                    print(f"ID:{book.book_id}")
                    print(f"书名:{book.title}")
                    print(f"作者:{book.author}")
                    print(f"价格:{book.price}")
                    print(f"ISBN:{book.isbn}")
                    print(f"状态:{book.status}")
                    found=True
            if not found:
                print("未找到该图书！")
        elif choice=='4':
            found = False
            isbn=input("请输入ISBN：")
            for book in self.books.values():
                if isbn in book.isbn:
                    print("找到图书")
                    print(f"ID:{book.book_id}")
                    print(f"书名:{book.title}")
                    print(f"作者:{book.author}")
                    print(f"价格:{book.price}")
                    print(f"ISBN:{book.isbn}")
                    print(f"状态:{book.status}")
                    found=True
            if not found:
                print("未找到该图书！")
        else:
            print("输入错误！")
    def borrow(self):
        if not self.current_user:
            print("请先登录！")
            return False
        if not self.books:
            print("目前库里没有图书可借！")
            return False
        id=input("请输入要借阅的图书ID：")
        if id not in self.books:
            print("未找到该图书！")
            return False
        if self.books[id].status=='已借出':
            print("图书已被借出，无法再次借阅！")
            return False
        self.books[id].status='已借出'
        self.save_data()
        print("借阅成功！")
        return True
    def return_book(self):
        if not self.current_user:
            print("请先登录！")
            return False
        id=input("请输入要归还的图书ID：")
        if id not in self.books:
            print("未找到该图书！")
            return False
        if self.books[id].status=='在馆':
            print("图书在馆，无需归还！")
            return False
        self.books[id].status='在馆'
        self.save_data()
        print("归还成功！")
        return True
    def register(self):
        if not self.users:
            new_id="1"
        else:
            max_id= max(int(user_id) for user_id in self.users)
            new_id=str(max_id+1)
        print(f"系统已自动分配用户ID:{new_id}")
        name=input("用户名：").strip()
        pwd=input("用户密码：").strip()
        question=input("安全问题：").strip()
        answer=input("问题答案：").strip()
        choice=input("用户类型(1.管理员/2.普通用户)：").strip()
        for new_name in self.users.values():
            if name in new_name.name:
                print("用户已存在！")
                return False
        if not name:
            print("用户名不能为空！")
            return False
        if not pwd:
            print("密码不能为空！")
            return False
        if not question:
            print("安全问题不能为空！")
            return False
        if not answer:
            print("问题答案不能为空！")
            return False
        if choice=='1':
            user_type='管理员'
        else:
            user_type='普通用户'
        user=User(new_id,name,pwd,question,answer,user_type)
        self.users[new_id]=user
        self.save_data()
        print("注册成功！")
        return True
    def login(self):
        name=input("请输入用户名：")
        users=self.users
        found_user=None
        for user in users.values():
            if name in user.name:
                found_user=user
                break
        if found_user is None:
            print("用户不存在！")
            return False
        pwd=input("请输入用户密码：")
        if pwd !=found_user.password:
            print("密码错误！")
            return False
        self.current_user=found_user
        print("登录成功！")
        return True
    def logout(self):
        if self.current_user:
            self.current_user=None
            print("谢谢使用！")
            return True
        else:
            print("请先登录！")
            return False
    def find_pwd(self):
        id=input("请输入用户ID:")
        if id not in self.users:
            print("用户不存在！")
            return False
        user=self.users[id]
        print(f"安全问题:{user.question}")
        answer=input("请输入答案：")
        if answer!=user.answer:
            print("答案错误，无法找回密码！")
            return False
        print(f"验证成功，密码是：{user.password}")
        return True
    def show_all_books(self):
        if not self.books:
            print("目前库中没有图书！")
            return False
        print("1.按ID升序")
        print("2.按书名升序(A-Z)")
        print("3.按价格升序")
        print("4.按价格降序")
        print("5.按状态排序(在馆优先)")
        choice=input("请选择排序方式：")
        books_list=list(self.books.values())
        if choice=='1':
            sorted_book=sorted(books_list,key=lambda x:int(x.book_id))
        elif choice=='2':
            sorted_book=sorted(books_list,key=lambda x:x.title.lower())
        elif choice=='3':
            sorted_book=sorted(books_list,key=lambda x:float(x.price))
        elif choice=='4':
            sorted_book=sorted(books_list,key=lambda x:float(x.price),reverse=True)
        elif choice=='5':
            sorted_book=sorted(books_list,key=lambda x:(0 if x.status=='在馆' else 1,int(x.book_id)))
        else:
            print("输入无效，默认按ID升序排序！")
            sorted_book=sorted(books_list,key=lambda x:int(x.book_id))
        print(f"{'ID':<5}{'书名':<30}{'作者':<15}{'价格':<10}{'ISBN':<18}{'状态':<8}")
        for book in sorted_book:
            print(f"{book.book_id:<5}{book.title:<30}{book.author:<15}{book.price:<10}{book.isbn:<18}{book.status:<8}")
