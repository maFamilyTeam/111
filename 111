import json
import os
import time

from matplotlib.style import library

USER_TYPE_ADMIN=1
USER_TYPE_NORMAL=2

class BookNode:
    def __init__(self,b_id,title,price,category,author,ISBN,borrow_cnt,status):
        self.b_id = b_id
        self.title = title
        self.price = price
        self.category = category
        self.author = author
        self.ISBN = ISBN
        self.status = status
        self.borrow_cnt=borrow_cnt
        self.next=None
class Library:
    def __init__(self):
        self.users={}
        self.users_file="users.json"
        self.books_file="books.json"
        self.head=None
        self.load_data()
        self._ensure_admin()


    def load_data(self):
        if os.path.exists(self.books_file):
            try:
                with open(self.books_file,'r',encoding="utf-8") as f:
                    books=json.load(f)
                    self.head=None
                    tail=None
                    for book in books:
                        node=BookNode(
                            book["b_id"],book["title"],book["price"],book["category"],
                            book["author"],book["ISBN"],book.get("borrow_cnt",0),book.get("status","在馆")
                        )
                        if not self.head:
                            self.head=node
                            tail=node
                        else:
                            tail.next=node
                            tail=tail.next
            except Exception:
                self.head=None
        if os.path.exists(self.users_file):
            try:
                with open(self.users_file,'r',encoding="utf-8") as f:
                    users=json.load(f)
                    self.users={}
                    for i,user in users.items():
                        self.users[i]={
                            "password":user.get("password",""),
                            "question":user.get("question",""),
                            "answer":user.get("answer",""),
                            "user_type":user.get("user_type",USER_TYPE_NORMAL),
                            "time":user.get("time",0),
                            "record":user.get("record",[])
                        }
            except Exception:
                self.users={}
    def save_data(self):
        books=[]
        curr=self.head
        while curr:
            book={
                "b_id":curr.b_id,
                "title":curr.title,
                "price":curr.price,
                "category":curr.category,
                "author":curr.author,
                "ISBN":curr.ISBN,
                "borrow_cnt":curr.borrow_cnt,
                "status":curr.status
            }
            books.append(book)
            curr=curr.next
        with open(self.books_file,'w',encoding="utf-8") as f:
            json.dump(books,f,ensure_ascii=False,indent=4)
        with open(self.users_file,"w",encoding="utf-8") as f:
            json.dump(self.users,f,ensure_ascii=False,indent=4)

    def _ensure_admin(self):
        has_admin=False
        for name,s in self.users.items():
            if s['user_type']==USER_TYPE_ADMIN:
                has_admin=True
                break
        if not has_admin:
            print("\n[系统] 未检测到管理员账号，请先创建管理员：")
            while True:
                name=input("请输入管理员用户名: ").strip()
                if not name:
                    print("输入不能为空，请重新输入")
                    continue
                if name in self.users:
                    print("用户名已存在，请换一个")
                    continue
                break
            while True:
                pwd = input("请输入管理员密码: ").strip()
                if not pwd:
                    print("密码不能为空，请重新输入")
                    continue
                break
            while True:
                question = input("请输入密保问题: ").strip()
                if not question:
                    print("密保问题不能为空，请重新输入")
                    continue
                break
            while True:
                answer = input("请输入问题答案: ").strip()
                if not answer:
                    print("答案不能为空，请重新输入")
                    continue
                break
            self.users[name]={
                "password":pwd,
                "question":question,
                "answer":answer,
                "user_type":USER_TYPE_ADMIN,
                "time":0,
                "record":[]
            }
            self.save_data()
            print(f"[系统] 管理员「{name}」创建成功，请使用该账号登录")
    def user_type_label(self,user_type):
        if user_type==USER_TYPE_NORMAL:
            return "普通用户"
        else:
            return "管理员"
    def safe_int(self,prompt):
        while True:
            n=input(prompt).strip()
            if n=="":
                print("输入不能为空！")
                continue
            try:
                return int(n)
            except ValueError:
                print("请输入有效整数！")

    def safe_float(self,prompt):
        while True:
            n = input(prompt).strip()
            if n == "":
                print("输入不能为空！")
                continue
            try:
                return float(n)
            except ValueError:
                print("请输入有效数字！")
    def safe_choice(self,prompt,valid_options):
        while True:
            s = input(prompt).strip()
            if s in valid_options:
                return s
            print(f"请输入有效选项之一：{valid_options}")
    def find_by_id(self,id):
        curr=self.head
        while curr:
            if curr.b_id==id:
                return curr
            curr = curr.next
        return None
    def check(self,name,author,ISBN,exclude_id=None):
        curr=self.head
        while curr:
            if curr.title==name and curr.author==author and curr.ISBN==ISBN:
                if curr.b_id==exclude_id and exclude_id is not None:
                    continue
                return True
            curr = curr.next
        return False
    def register(self):
        name = input("新用户名: ").strip()
        if not name:
            print("用户名不能为空！")
            return
        if name in self.users:
            print("该用户名已存在！")
            return
        pwd = input("设置密码: ").strip()
        if not pwd:
            print("密码不能为空！")
            return
        question=input("设置密保问题: ").strip()
        if not question:
            print("密保问题不能为空！")
            return
        answer= input("设置密保答案: ").strip()
        if not answer:
            print("密保答案不能为空！")
            return
        self.users[name]={
            "password":pwd,
            "question":question,
            "answer":answer,
            "time":0,
            "record":[],
            "user_type":USER_TYPE_NORMAL
        }
        self.save_data()
        print("注册成功！")
    def change_password(self,name):
        old_pwd = input("请输入旧密码: ").strip()
        if old_pwd!=self.users[name]["password"]:
            print("旧密码错误！")
            return
        new_pwd = input("请输入新密码: ").strip()
        if not new_pwd:
            print("新密码不能为空！")
            return
        self.users[name]["password"] = new_pwd
        self.save_data()
        print("密码修改成功！")
    def find_pwd(self):
        name = input("请输入用户名: ").strip()
        if name not in self.users:
            print("该用户不存在！")
            return
        print(f"密保问题:{self.users[name]['question']}")
        answer = input("请输入答案:").strip()
        if answer != self.users[name]["answer"]:
            print("密保回答错误！")
            return
        new_pwd = input("验证成功！请输入新密码: ").strip()
        if not new_pwd:
            print("新密码不能为空！")
            return
        self.users[name]["password"] = new_pwd
        self.save_data()
        print("密码已重置！")
    def add_book(self):
        b_id = self.safe_int("输入图书编号(整数): ")
        if self.find_by_id(b_id):
            print("该编号已存在，录入失败！（编号不能重复）")
            return
        name = input("输入书名: ").strip()
        if not name:
            print("书名不能为空！")
            return
        price = self.safe_float("输入价格: ")
        category = input("输入类别(如 计算机/文学): ").strip()
        if not category:
            print("类别不能为空！")
            return
        author = input("输入作者: ").strip()
        if not author:
            print("作者不能为空！")
            return
        ISBN = input("ISBN: ").strip()
        if not ISBN:
            print("ISBN不能为空！")
            return
        if self.check(name,author,ISBN):
            confirm = input("系统中已存在同名同作者的图书，是否仍要添加？(y/n): ").strip().lower()
            if confirm != 'y':
                print("已取消录入。")
                return
        bc=0
        new_node=BookNode(b_id,name,price,category,author,ISBN,bc,"在馆")
        if not self.head:
            self.head = new_node
        else:
            temp=self.head
            while temp.next:
                temp=temp.next
            temp.next=new_node
        self.save_data()
        print("图书录入成功！")
    def delete_book(self):
        b_id = self.safe_int("输入要删除的图书编号: ")
        if not self.head:
            print("当前没有图书！")
            return
        if self.head.b_id == b_id:
            self.head=self.head.next
            self.save_data()
            print("删除成功!")
            return
        temp=self.head
        while temp.next:
            if temp.next.b_id == b_id:
                temp.next=temp.next.next
                self.save_data()
                print("删除成功！")
                return
            temp=temp.next
        print("未找到该图书！")
    def modify_book(self):
        b_id = self.safe_int("输入要修改的图书编号: ")
        node=self.find_by_id(b_id)
        if not node:
            print("未找到该图书！")
            return
        print("当前信息：")
        print(f"  编号: {node.b_id}  书名: {node.title}  价格: {node.price}  "
              f"类别: {node.category}  作者: {node.author}  状态: {node.status}")
        print("（直接回车表示该项不修改）")
        new_name = input(f"新书名 [{node.title}]: ").strip()
        if new_name:
            node.title = new_name
        try:
            new_price = float(input(f"新价格[{node.price}]:"))
        except:
            new_price = None
        if new_price:
            node.price = new_price
        new_cat = input(f"新类别 [{node.category}]: ").strip()
        if new_cat:
            node.category = new_cat
        new_author = input(f"新作者 [{node.author}]: ").strip()
        if new_author:
            node.author = new_author
        ISBN= input(f"新ISBN [{node.ISBN}]: ").strip()
        if ISBN:
            node.ISBN = ISBN
        self.save_data()
        print("修改成功！")



    def search_book(self):
        """多种查询：按编号精确查 / 按书名、作者、类别关键字模糊查（遍历链表）。"""
        print("\n查询方式：1.按编号  2.按书名  3.按作者  4.按类别")
        choice = self.safe_choice("请选择(1-4): ", ["1", "2", "3", "4"])
        found = False
        if choice == '1':
            b_id = self.safe_int("输入编号: ")
            node = self.find_by_id(b_id)
            if node:
                print(f"  编号: {node.b_id}  书名: {node.title}  价格: {node.price}  "
                      f"类别: {node.category}  作者: {node.author}  状态: {node.status}")
                found = True
        elif choice == '2':
            keyword = input("输入书名关键字: ").strip().lower()
            curr = self.head
            while curr:
                if keyword in curr.title.lower():
                    print(f"  编号: {curr.b_id}  书名: {curr.title}  价格: {curr.price}  "
                          f"类别: {curr.category}  作者: {curr.author}  状态: {curr.status}")
                    found = True
                curr = curr.next
        elif choice == '3':
            keyword = input("输入作者关键字: ").strip().lower()
            curr = self.head
            while curr:
                if keyword in curr.author.lower():
                    print(f"  编号: {curr.b_id}  书名: {curr.title}  价格: {curr.price}  "
              f"类别: {curr.category}  作者: {curr.author}  状态: {curr.status}")
                    found = True
                curr = curr.next
        elif choice == '4':
            keyword = input("输入类别关键字: ").strip().lower()
            curr = self.head
            while curr:
                if keyword in curr.category.lower():
                    print(f"  编号: {curr.b_id}  书名: {curr.title}  价格: {curr.price}  "
                          f"类别: {curr.category}  作者: {curr.author}  状态: {curr.status}")
                    found = True
                curr = curr.next
        if not found:
            print("未找到符合条件的图书。")
    def borrow_book(self,curr):
        b_id = self.safe_int("输入要借阅的图书编号: ")
        node = self.find_by_id(b_id)
        if not node:
            print("未找到该编号的图书！")
            return
        if node.status == "已借出":
            print("该书已被借出，无法借阅！")
            return
        node.status = "已借出"
        node.borrow_cnt=int(node.borrow_cnt)+1
        self.users[curr]['record'].append(b_id)
        self.save_data()
        print(f"借阅成功！《{node.title}》")

    def return_book(self,curr):
        b_id = self.safe_int("输入要归还的图书编号: ")
        node = self.find_by_id(b_id)
        if not node:
            print("未找到该编号的图书！")
            return
        if node.status == "在馆":
            print("该书当前在馆，无需归还！")
            return
        node.status = "在馆"
        found=False
        for index, item in enumerate(self.users[curr]['record']):
            if item ==b_id:
                del self.users[curr]['record'][index]
                found=True
        if not found:
            print("无借阅记录，无需归还")
            return
        self.save_data()
        print(f"归还成功！《{node.title}》")
    def swap_node_data(self, node1, node2):
        node1.b_id, node2.b_id = node2.b_id, node1.b_id
        node1.title, node2.title = node2.title, node1.title
        node1.price, node2.price = node2.price, node1.price
        node1.category, node2.category = node2.category, node1.category
        node1.ISBN,node2.ISBN = node2.ISBN, node1.ISBN
        node1.author, node2.author = node2.author, node1.author
        node1.borrow_cnt, node2.borrow_cnt = node2.borrow_cnt, node1.borrow_cnt
        node1.status, node2.status = node2.status, node1.status
    def bubble_sort(self, by="b_id"):
        if not self.head or not self.head.next:
            return
       # 根据排序依据取可比的关键字
        def key_func(n):
            if by == "b_id":
                return n.b_id
            if by == "price":
                return n.price
            if by =="borrow_cnt":
                return n.borrow_cnt
            return n.title

        swapped = True
        while swapped:
            swapped = False
            curr = self.head
            while curr.next:
                if key_func(curr) > key_func(curr.next):
                    self.swap_node_data(curr, curr.next)
                    swapped = True
                curr = curr.next
        self.save_data()
        name_map = {"b_id": "编号", "price": "价格","ISBN":"ISBN","title": "书名"}
        print(f"已按{name_map.get(by, by)}排序！")
    def sort_menu(self):
        print("\n排序方式：1.按编号  2.按价格 3.按书名")
        c = self.safe_choice("请选择(1-3): ", ["1", "2", "3"])
        if c == "1":
            self.bubble_sort("b_id")
        elif c == "2":
            self.bubble_sort("price")
        else:
            self.bubble_sort("title")
        self.display()
    def display(self):
        if not self.head:
            print("\n当前没有图书。")
            return
        print(f"\n{'编号':<12} {'书名':<25} {'价格':<12} {'类别':<8} {'作者':<20} {'ISBN':<20} {'状态':<8}")
        print("-" * 130)
        curr = self.head
        while curr:
            print(f"{curr.b_id:<12} {curr.title:<26} {curr.price:<13}"
                  f"{curr.category:<9} {curr.author:<20} {curr.ISBN:<21} {curr.status:<9}")
            curr = curr.next
    def stats_by_category(self):
        if not self.head:
            print("当前没有图书。")
            return
        stat = {}
        curr = self.head
        while curr:
            if curr.category not in stat:
                stat[curr.category] = {"total": 0, "在馆": 0, "已借出": 0}
            stat[curr.category]["total"] += 1
            stat[curr.category][curr.status] = stat[curr.category].get(curr.status, 0) + 1
            curr = curr.next
        print(f"\n{'类别':<12} {'总数':<6} {'在馆':<6} {'已借出':<6}")
        print("-" * 32)
        for cat, v in stat.items():
            print(f"{cat:<12} {v['total']:<6} {v['在馆']:<6} {v['已借出']:<6}")
    def print_record(self,curr):
        if self.users[curr]['record']:
            print(self.users[curr]['record'])
        else:
            print("暂无借阅记录")
    def popular_books(self):
        if not self.head or not self.head.next:
            return

        swapped = True
        while swapped:
            swapped = False
            curr = self.head
            while curr.next:
                if curr.borrow_cnt < curr.next.borrow_cnt:
                    self.swap_node_data(curr, curr.next)
                    swapped = True
                curr = curr.next
        node = self.head
        print("="*50+" "*10 + "热 门 图 书"+" "*10 + "="*60 )
        print(f"\n{'编号':<12} {'书名':<25} {'价格':<12} {'类别':<8} {'作者':<20} {'ISBN':<20} {'状态':<8}")
        print("-"*120)
        for i in range(5):
            if node.next:
                print(f"{node.b_id:<12} {node.title:<26} {node.price:<13}"
                      f"{node.category:<9} {node.author:<20} {node.ISBN:<21} {node.status:<9}")
                node = node.next

